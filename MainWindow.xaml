<Window x:Class="AdGroupUserExporter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AD Group User Exporter" Height="820" Width="1320" MinHeight="720" MinWidth="1080"
        Background="{DynamicResource WindowBackgroundBrush}" Foreground="{DynamicResource TextBrush}">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Padding" Value="10,3" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{DynamicResource DisabledBackgroundBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="RowBackground" Value="{DynamicResource PanelBackgroundBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource AlternateRowBackgroundBrush}" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource BorderBrush}" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource HeaderBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectionBackgroundBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource SelectionTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" Background="{DynamicResource PanelBackgroundBrush}" BorderThickness="1" CornerRadius="6" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1.4*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Gruppenmuster" FontWeight="SemiBold" />
                <ComboBox Grid.Row="1" Grid.Column="0" x:Name="GroupPatternComboBox" Margin="0,6,8,0" Height="30"
                          IsEditable="True" IsTextSearchEnabled="False" Text="abc*_1a*" />

                <TextBlock Grid.Row="0" Grid.Column="1" Text="SearchBase optional" FontWeight="SemiBold" />
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="SearchBaseTextBox" Margin="0,6,12,0" Height="30" />

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Domain Controller optional" FontWeight="SemiBold" />
                <TextBox Grid.Row="1" Grid.Column="2" x:Name="ServerTextBox" Margin="0,6,12,0" Height="30" />

                <TextBlock Grid.Row="0" Grid.Column="3" Text="Theme" FontWeight="SemiBold" />
                <ComboBox Grid.Row="1" Grid.Column="3" x:Name="ThemeComboBox" Width="105" Height="30" Margin="0,6,12,0"
                          SelectionChanged="ThemeComboBox_SelectionChanged">
                    <ComboBoxItem Content="Hell" Tag="Light" />
                    <ComboBoxItem Content="Dunkel" Tag="Dark" />
                </ComboBox>

                <Button Grid.Row="1" Grid.Column="4" x:Name="RemovePatternButton" Content="Eintrag entfernen" Width="130" Height="32" Margin="0,6,12,0"
                        Click="RemovePatternButton_Click" ToolTip="Entfernt das aktuelle Gruppenmuster aus dem Verlauf" />
                <CheckBox Grid.Row="1" Grid.Column="5" x:Name="OnlyEnabledCheckBox" Content="Nur aktive Benutzer" Margin="0,9,16,0" IsChecked="True" />
                <Button Grid.Row="1" Grid.Column="6" x:Name="SearchButton" Content="Suchen" Width="110" Height="32" Click="SearchButton_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" Background="{DynamicResource PanelBackgroundBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="User 1" FontWeight="SemiBold" />
                <ComboBox Grid.Row="1" Grid.Column="0" x:Name="CompareUserAComboBox" Margin="0,6,12,0" Height="30"
                          IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True" MaxDropDownHeight="260"
                          GotKeyboardFocus="CompareUserComboBox_GotKeyboardFocus" PreviewMouseLeftButtonDown="CompareUserComboBox_PreviewMouseLeftButtonDown"
                          ToolTip="User aus der geladenen Liste auswaehlen oder per Teiltext suchen" />

                <TextBlock Grid.Row="0" Grid.Column="1" Text="User 2" FontWeight="SemiBold" />
                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="CompareUserBComboBox" Margin="0,6,12,0" Height="30"
                          IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True" MaxDropDownHeight="260"
                          GotKeyboardFocus="CompareUserComboBox_GotKeyboardFocus" PreviewMouseLeftButtonDown="CompareUserComboBox_PreviewMouseLeftButtonDown"
                          ToolTip="User aus der geladenen Liste auswaehlen oder per Teiltext suchen" />

                <Button Grid.Row="1" Grid.Column="2" x:Name="CompareUsersButton" Content="User vergleichen" Width="150" Height="32" Margin="0,6,0,0"
                        Click="CompareUsersButton_Click" />
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0" x:Name="FilterTextBox" Height="32" VerticalContentAlignment="Center"
                     TextChanged="FilterTextBox_TextChanged" ToolTip="Filtert ueber alle sichtbaren Spalten" />
            <Button Grid.Column="1" x:Name="CopyButton" Content="GroupName kopieren" Width="170" Height="32" Margin="12,0,0,0"
                    Click="CopyButton_Click" IsEnabled="False" />
            <Button Grid.Column="2" x:Name="ExportButton" Content="Gefiltertes Ergebnis als CSV" Width="220" Height="32" Margin="12,0,0,0"
                    Click="ExportButton_Click" IsEnabled="False" />
        </Grid>

        <Grid Grid.Row="3">
            <DataGrid x:Name="ResultsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Extended"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="GroupName" Binding="{Binding GroupName}" Width="190" />
                    <DataGridTextColumn Header="GroupPath" Binding="{Binding GroupPath}" Width="260" />
                    <DataGridTextColumn Header="SamAccountName" Binding="{Binding SamAccountName}" Width="150" />
                    <DataGridTextColumn Header="DisplayName" Binding="{Binding DisplayName}" Width="190" />
                    <DataGridTextColumn Header="Mail" Binding="{Binding Mail}" Width="230" />
                    <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled}" Width="80" />
                    <DataGridTextColumn Header="Department" Binding="{Binding Department}" Width="150" />
                    <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="180" />
                    <DataGridTextColumn Header="DistinguishedName" Binding="{Binding DistinguishedName}" Width="360" />
                </DataGrid.Columns>
            </DataGrid>

            <DataGrid x:Name="ComparisonGrid" AutoGenerateColumns="False" IsReadOnly="True" Visibility="Collapsed"
                      CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Extended"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="130" />
                    <DataGridTextColumn Header="GroupName" Binding="{Binding GroupName}" Width="260" />
                    <DataGridTextColumn Header="User 1" Binding="{Binding UserA}" Width="130" />
                    <DataGridTextColumn Header="User 2" Binding="{Binding UserB}" Width="130" />
                    <DataGridTextColumn Header="GroupPath User 1" Binding="{Binding GroupPathA}" Width="*" MinWidth="280" />
                    <DataGridTextColumn Header="GroupPath User 2" Binding="{Binding GroupPathB}" Width="*" MinWidth="280" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <DockPanel Grid.Row="4" Margin="0,10,0,0">
            <ProgressBar x:Name="BusyProgress" DockPanel.Dock="Left" Width="140" Height="16" IsIndeterminate="True" Visibility="Collapsed" Margin="0,0,12,0" />
            <TextBlock x:Name="StatusTextBlock" VerticalAlignment="Center" Text="Bereit" />
        </DockPanel>
    </Grid>
</Window>
