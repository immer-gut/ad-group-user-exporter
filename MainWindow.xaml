<Window x:Class="AdGroupUserExporter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AD Group User Exporter" Height="760" Width="1220" MinHeight="640" MinWidth="980">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="6" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1.4*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Gruppenmuster" FontWeight="SemiBold" />
                <ComboBox Grid.Row="1" Grid.Column="0" x:Name="GroupPatternComboBox" Margin="0,6,8,0" Height="30"
                          IsEditable="True" IsTextSearchEnabled="False" Text="abc*_1a*" />

                <TextBlock Grid.Row="0" Grid.Column="1" Text="SearchBase optional" FontWeight="SemiBold" />
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="SearchBaseTextBox" Margin="0,6,12,0" Height="30" />

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Domain Controller optional" FontWeight="SemiBold" />
                <TextBox Grid.Row="1" Grid.Column="2" x:Name="ServerTextBox" Margin="0,6,12,0" Height="30" />

                <Button Grid.Row="1" Grid.Column="3" x:Name="RemovePatternButton" Content="Eintrag entfernen" Width="130" Height="32" Margin="0,6,12,0"
                        Click="RemovePatternButton_Click" ToolTip="Entfernt das aktuelle Gruppenmuster aus dem Verlauf" />
                <CheckBox Grid.Row="1" Grid.Column="4" x:Name="OnlyEnabledCheckBox" Content="Nur aktive Benutzer" Margin="0,9,16,0" IsChecked="True" />
                <Button Grid.Row="1" Grid.Column="5" x:Name="SearchButton" Content="Suchen" Width="110" Height="32" Click="SearchButton_Click" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0" x:Name="FilterTextBox" Height="32" VerticalContentAlignment="Center"
                     TextChanged="FilterTextBox_TextChanged" ToolTip="Filtert ueber alle sichtbaren Spalten" />
            <Button Grid.Column="1" x:Name="CopyButton" Content="GroupName kopieren" Width="170" Height="32" Margin="12,0,0,0"
                    Click="CopyButton_Click" IsEnabled="False" />
            <Button Grid.Column="2" x:Name="ExportButton" Content="Gefiltertes Ergebnis als CSV" Width="220" Height="32" Margin="12,0,0,0"
                    Click="ExportButton_Click" IsEnabled="False" />
        </Grid>

        <DataGrid Grid.Row="2" x:Name="ResultsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Extended"
                  GridLinesVisibility="Horizontal" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="GroupName" Binding="{Binding GroupName}" Width="190" />
                <DataGridTextColumn Header="GroupPath" Binding="{Binding GroupPath}" Width="260" />
                <DataGridTextColumn Header="SamAccountName" Binding="{Binding SamAccountName}" Width="150" />
                <DataGridTextColumn Header="DisplayName" Binding="{Binding DisplayName}" Width="190" />
                <DataGridTextColumn Header="Mail" Binding="{Binding Mail}" Width="230" />
                <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled}" Width="80" />
                <DataGridTextColumn Header="Department" Binding="{Binding Department}" Width="150" />
                <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="180" />
                <DataGridTextColumn Header="DistinguishedName" Binding="{Binding DistinguishedName}" Width="360" />
            </DataGrid.Columns>
        </DataGrid>

        <DockPanel Grid.Row="3" Margin="0,10,0,0">
            <ProgressBar x:Name="BusyProgress" DockPanel.Dock="Left" Width="140" Height="16" IsIndeterminate="True" Visibility="Collapsed" Margin="0,0,12,0" />
            <TextBlock x:Name="StatusTextBlock" VerticalAlignment="Center" Text="Bereit" />
        </DockPanel>
    </Grid>
</Window>
